:: PassageFooter {"position":"400,25","size":"100,100"}
<<nobr>>
<<if tags().includes("setup")>>
<<elseif tags().includes("sim")>>
<div id="sim-footer" class="sim-footer-pinned">
	<h3 class="sim-footer-heading">Sim Controls</h3>
	<div class="sim-footer-links">
		<<displaySimProgressLinks>>
		<hr>
	</div>
	<div class="sim-footer-audio">
		<h4 class="sim-footer-subheading">Audio controls</h4>
		<div class="sim-footer-audio-buttons">
			<<button "Hold Music">>
				<<audio "hold_music" loop play>>
			<</button>>
			<<button "PA Announcement">>
				<<audio "pa_announcement" play>>
			<</button>>
			<<button "Bodily Function">>
				<<audio "bodily_function" play>>
			<</button>>
		</div>
		<div class="sim-footer-audio-stop">
			<<button "Stop Audio">>
				<<audio ":all" stop>>
			<</button>>
		</div>
	</div>
</div>
<</if>>
<</nobr>>

